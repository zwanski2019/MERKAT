{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    {
      "identifier": "sql:allow-execute",
      "allow": [{ "url": "sqlite:merkat.db" }]
    },
    "updater:default"
  ]
}
