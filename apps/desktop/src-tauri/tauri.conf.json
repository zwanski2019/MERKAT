{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MERKAT",
  "version": "0.0.0",
  "identifier": "com.merkat.pos",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @merkat/web dev",
    "beforeBuildCommand": "pnpm --filter @merkat/web build"
  },
  "app": {
    "windows": [
      {
        "title": "MERKAT",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "publisher": "MERKAT",
    "category": "Business",
    "shortDescription": "Operator-grade POS for retail and restaurant",
    "longDescription": "MERKAT is a white-label, offline-first point-of-sale operating system for retail and restaurant merchants.",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "both",
        "languages": [
          "English"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://releases.merkat.example/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGN0M5QUEyRjQzQTE5QjEKUldTeEdUcjBvcHA4MzhUUkdPMjZFdFZ2aUx1TG9HOXJJcVFNRHJobHl4YVFLbWRxcEpUQzBpMUsK"
    }
  }
}
